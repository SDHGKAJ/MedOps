    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "express-validator": "^7.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "selenium-webdriver": "^4.15.0",
    "chromedriver": "^121.0.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  }
